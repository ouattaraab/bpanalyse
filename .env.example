# --- App ---
APP_NAME="BP Explorer"
APP_ENV=local
APP_KEY=
APP_LOCALE=fr

# --- Base de données (PostgreSQL + pgvector) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bp_explorer
DB_USERNAME=postgres
DB_PASSWORD=

# --- Queue ---
QUEUE_CONNECTION=database

# --- Broadcast temps réel (Laravel Reverb / WebSocket) ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=bp-explorer
REVERB_APP_KEY=bp-local-key
REVERB_APP_SECRET=bp-local-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Souveraineté : true = tout sur vLLM/whisper/xtts auto-hébergés ---
AI_SOVEREIGN=false

# --- LLM (clés) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=qwen2.5-7b-instruct

# --- Routage LLM par feature (laisser par défaut sauf besoin) ---
LLM_CHAT=groq
LLM_PRESENTATION=groq
LLM_DEBATE=claude
LLM_FINANCIAL=claude
LLM_SUMMARY=groq

# --- STT / TTS / Embeddings ---
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
EMBEDDING_PROVIDER=bge_m3
EMBEDDING_MODEL=BAAI/bge-m3
# Délai max du process d'embeddings (s). Le 1er chargement du modèle peut être lent.
EMBEDDING_TIMEOUT=1800

# Ingestion : lancer via la file (php artisan queue:work), pas en QUEUE_CONNECTION=sync,
# pour éviter d'empiler Docling et bge-m3 (torch) en mémoire dans un seul process.
